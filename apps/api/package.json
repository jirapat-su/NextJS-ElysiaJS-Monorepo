{
  "name": "api",
  "type": "module",
  "version": "0.0.0",
  "module": "src/main.ts",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:standalone": "bun run build && bun build --compile --minify-whitespace --minify-syntax --outfile ./dist/standalone/server ./dist/server/index.mjs",
    "start": "cross-env NODE_ENV=production bun run dist/server/index.mjs",
    "lint": "tsc --noEmit && biome check --write --no-errors-on-unmatched --files-ignore-unknown=true .",
    "format": "tsc --noEmit && biome format --write .",
    "_____________auth_scripts_____________": "",
    "auth:generate": "bunx @better-auth/cli generate --config ./src/libs/auth/index.ts",
    "__________prisma_app_scripts__________": "",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.5.4",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@keyv/redis": "^5.1.6",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@t3-oss/env-core": "^0.13.10",
    "better-auth": "1.5.4",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "elysia": "^1.4.27",
    "keyv": "^5.6.0",
    "mysql2": "^3.19.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "bun-types": "^1.3.10",
    "nitro": "^3.0.1-alpha.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
